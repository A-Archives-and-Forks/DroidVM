local.properties

# build.sh stages the compiled network/boot binaries next to the committed
# 7za prebuilt; only 7za is tracked, the rest are build output.
/app/src/thirdparty
/app/src/main/assets/bin/*/bridgedhcp
/app/src/main/assets/bin/*/gvswitch
/app/src/main/assets/bin/*/lbx
/app/src/main/assets/bin/*/netbox
/app/src/main/assets/bin/*/pbridge

# Terminal font: build.sh fetches the ~2.3MB Maple Mono NL NF TTF on first
# build; only the OFL license text under app/src/main/assets/fonts is committed.
/app/src/main/assets/fonts/*.ttf
